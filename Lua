-- ─────────────────────────────────────────────────────────────
--  PROJECTILE TRACKING  (CoreProjectile only — Rivals specific)
-- ─────────────────────────────────────────────────────────────
local projTracked = {}

local function startProjVoid()
    if Config.ProjChildAdd then Config.ProjChildAdd:Disconnect() end
    if Config.ProjChildRem then Config.ProjChildRem:Disconnect() end
    if Config.ProjConn     then Config.ProjConn:Disconnect()     end

    local VOID = CFrame.new(9e3, 9e3, 9e3)

    Config.ProjChildAdd = workspace.ChildAdded:Connect(function(o)
        if o.Name == "CoreProjectile" and o:IsA("BasePart") then
            projTracked[o] = true
        end
    end)

    -- also catch projectiles parented inside models
    workspace.DescendantAdded:Connect(function(o)
        if o.Name == "CoreProjectile" and o:IsA("BasePart") then
            projTracked[o] = true
        end
    end)

    Config.ProjChildRem = workspace.ChildRemoved:Connect(function(o)
        projTracked[o] = nil
    end)

    -- scan existing
    for _, d in ipairs(workspace:GetDescendants()) do
        if d.Name == "CoreProjectile" and d:IsA("BasePart") then
            projTracked[d] = true
        end
    end

    Config.ProjConn = RunService.Heartbeat:Connect(function()
        if not Config.ProjVoidEnabled then return end
        local vcf = VOID
        for part in pairs(projTracked) do
            if part and part.Parent then
                part.CFrame = vcf
                part.AssemblyLinearVelocity  = Vector3.zero
                part.AssemblyAngularVelocity = Vector3.zero
            else
                projTracked[part] = nil
            end
        end
    end)
end

local function stopProjVoid()
    if Config.ProjChildAdd then Config.ProjChildAdd:Disconnect() Config.ProjChildAdd=nil end
    if Config.ProjChildRem then Config.ProjChildRem:Disconnect() Config.ProjChildRem=nil end
    if Config.ProjConn     then Config.ProjConn:Disconnect()     Config.ProjConn=nil     end
    projTracked = {}
end

-- ─────────────────────────────────────────────────────────────
--  TARGET SELECTION
-- ─────────────────────────────────────────────────────────────
local function getTarget()
    if #playerCache == 0 then return nil end

    if Config.TargetMode == "Closest" then
        return getNearestEnemy()

    elseif Config.TargetMode == "LowestHP" then
        local best, bHP = nil, math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health < bHP then
                bHP=hum.Health best=p
            end
        end
        return best

    elseif Config.TargetMode == "HighestHP" then
        local best, bHP = nil, -math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health > bHP then
                bHP=hum.Health best=p
            end
        end
        return best
    end

    return getNearestEnemy()
end

-- ─────────────────────────────────────────────────────────────
--  PING-COMPENSATED SHOT TIMING
--
--  Rivals slingshot is validated server-side using the time
--  the projectile was created vs when it hits.
--  Higher ping = more "lead time" you need to fire earlier.
--  We scale HideTime so we appear, fire, then vanish before
--  the server's AC tick can react.
-- ─────────────────────────────────────────────────────────────
local function getScaledHideTime()
    if not Config.SlingPingScale then return Config.HideTime end
    local ping   = getPing()
    --[[
        At 30ms ping:  HideTime stays as configured
        At 80ms ping:  HideTime × 0.85  (appear faster, fire earlier)
        At 150ms ping: HideTime × 0.7   (fire significantly earlier)
        At 200ms+:     HideTime × 0.55  (very early fire window)

        The idea: high ping means server processes our shot later,
        so we need to fire sooner in our local timeline so the shot
        arrives at the server during the same valid window.
    ]]
    local scale = math.clamp(1 - (ping - 30) / 400, 0.55, 1.0)
    return Config.HideTime * scale
end

local function getScaledAttackTime()
    if not Config.SlingPingScale then return Config.AttackTime end
    local ping  = getPing()
    --[[
        At high ping we stay on target slightly longer because
        our fire remotes take longer to reach the server.
        Gives the packet time to arrive before we teleport away.
    ]]
    local scale = math.clamp(1 + (ping - 30) / 300, 1.0, 1.8)
    return Config.AttackTime * scale
end

-- ─────────────────────────────────────────────────────────────
--  FIRE  —  shoots every possible remote in the equipped tool
-- ─────────────────────────────────────────────────────────────
local SHOOT_KEYWORDS = {
    "shoot","fire","attack","cast","launch","throw",
    "use","action","hit","trigger","release",
}

local function fireCurrentTool()
    local chr  = LP.Character
    if not chr then return end
    local tool = chr:FindFirstChildOfClass("Tool")
    if not tool then return end

    -- Activate fires client-side animation + may trigger server
    pcall(function() tool:Activate() end)

    -- Scan all descendants for remotes
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local nl = v.Name:lower()
            for _, kw in ipairs(SHOOT_KEYWORDS) do
                if nl:find(kw) then
                    pcall(function() v:FireServer() end)
                    break
                end
            end
        end
    end
end

-- ─────────────────────────────────────────────────────────────
--  VOID SPAM CYCLE
--  Phase 1 ─ sink underground (hide from opponent's screen)
--  Phase 2 ─ snap onto target + fire
--  Phase 3 ─ return to original position
--
--  Why this beats HvH:
--    Your opponent's bypass voids enemies every Heartbeat.
--    While you're underground you don't exist in normal space
--    so their void loop voids thin air.
--    You snap up for ~100ms, fire, then vanish again.
--    At high ping their loop hasn't caught up yet.
-- ─────────────────────────────────────────────────────────────
local function runCycle()
    if Config.Running then return end
    Config.Running = true

    local target = getTarget()
    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")

    if not myHRP then
        Config.Running = false
        return
    end

    local origCF = myHRP.CFrame

    -- jitter on hide pos so pattern is unpredictable
    local jx = Config.JitterEnabled and (math.random() - 0.5) * 2 * Config.JitterRange or 0
    local jz = Config.JitterEnabled and (math.random() - 0.5) * 2 * Config.JitterRange or 0

    local hideCF = CFrame.new(
        origCF.Position.X + jx,
        Config.HideY,
        origCF.Position.Z + jz
    )

    -- ── PHASE 1: sink underground ──
    myHRP.CFrame = hideCF
    myHRP.AssemblyLinearVelocity  = Vector3.zero
    myHRP.AssemblyAngularVelocity = Vector3.zero

    task.wait(getScaledHideTime())

    -- ── PHASE 2: snap to target + fire ──
    local tChr = target and target.Character
    local tHRP = tChr and tChr:FindFirstChild("HumanoidRootPart")

    if tHRP then
        -- land just above target so shot is point-blank
        local snapCF = CFrame.new(
            tHRP.Position.X,
            tHRP.Position.Y + 2.5,
            tHRP.Position.Z
        ) * CFrame.Angles(0, math.random(0, 628)/100, 0)

        myHRP.CFrame = snapCF
        myHRP.AssemblyLinearVelocity  = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero

        -- Fire N shots with tiny delay between them
        if Config.SlingEnabled then
            for i = 1, Config.SlingShots do
                fireCurrentTool()
                if i < Config.SlingShots then
                    task.wait(Config.SlingDelay)
                end
            end
        end

        task.wait(getScaledAttackTime())
    end

    -- ── PHASE 3: return ──
    myHRP.CFrame = hideCF  -- dip back first so return isn't seen
    myHRP.AssemblyLinearVelocity  = Vector3.zero
    task.wait(Config.ReturnDelay)

    myHRP.CFrame = origCF
    myHRP.AssemblyLinearVelocity  = Vector3.zero

    Config.Running = false
end

-- ─────────────────────────────────────────────────────────────
--  START / STOP
-- ─────────────────────────────────────────────────────────────
local function startVoidSpam()
    Config.Enabled = true
    Config.Running = false

    if Config.ProjVoidEnabled then startProjVoid() end

    Config.CycleConn = RunService.Heartbeat:Connect(function()
        if Config.Enabled and not Config.Running then
            task.spawn(runCycle)
        end
    end)
end

local function stopVoidSpam()
    Config.Enabled = false
    Config.Running = false
    if Config.CycleConn then Config.CycleConn:Disconnect() Config.CycleConn=nil end
    stopProjVoid()

    -- snap back to spawn if we got stuck underground
    pcall(function()
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Position.Y < -50 then
            local sp = workspace:FindFirstChild("SpawnLocation")
            hrp.CFrame = sp and sp.CFrame + Vector3.new(0,5,0)
                           or CFrame.new(0, 10, 0)
        end
    end)
end

