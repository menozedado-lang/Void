-- ── toggle row ───────────────────────────────────────────────
local function mkToggle(title, sub, cfgKey, onColor)
    local h   = isMobile and 62 or 54
    onColor   = onColor or C.accent

    local card = Instance.new("Frame")
    card.LayoutOrder      = nextOrder()
    card.Size             = UDim2.new(1, 0, 0, h)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    mkCorner(card, 12)
    local cs = mkStroke(card, C.off, 1.5)

    local tLbl = mkLabel(card, title, isMobile and 14 or 13, C.text, Enum.Font.GothamBold)
    tLbl.Size     = UDim2.new(1, -90, 0, 20)
    tLbl.Position = UDim2.fromOffset(12, h/2 - (sub~="" and 14 or 10))

    if sub ~= "" then
        local sLbl = mkLabel(card, sub, isMobile and 11 or 10, C.sub, Enum.Font.Gotham)
        sLbl.Size     = UDim2.new(1, -90, 0, 14)
        sLbl.Position = UDim2.fromOffset(12, h/2 + 2)
    end

    -- pill
    local pill = Instance.new("Frame")
    pill.Size             = UDim2.fromOffset(isMobile and 58 or 52, isMobile and 28 or 24)
    pill.Position         = UDim2.new(1, -(isMobile and 68 or 62),
                                       0.5, -(isMobile and 14 or 12))
    pill.BackgroundColor3 = Config[cfgKey] and onColor or C.off
    pill.BorderSizePixel  = 0
    pill.Parent           = card
    mkCorner(pill, isMobile and 14 or 12)

    local knob = Instance.new("Frame")
    local kSize = isMobile and 20 or 18
    knob.Size             = UDim2.fromOffset(kSize, kSize)
    knob.Position         = Config[cfgKey]
        and UDim2.fromOffset((isMobile and 58 or 52) - kSize - 4, 4)
        or  UDim2.fromOffset(4, 4)
    knob.BackgroundColor3 = C.white
    knob.BorderSizePixel  = 0
    knob.Parent           = pill
    mkCorner(knob, kSize/2)

    local pillTxt = mkLabel(pill,
        Config[cfgKey] and "ON" or "OFF",
        9, C.white, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
    pillTxt.Size = UDim2.fromScale(1, 1)

    local hit = Instance.new("TextButton")
    hit.Size               = UDim2.fromScale(1, 1)
    hit.BackgroundTransparency = 1
    hit.Text               = ""
    hit.ZIndex             = 5
    hit.Parent             = card

    local function refresh()
        local on  = Config[cfgKey]
        local kOff = (isMobile and 58 or 52) - kSize - 4
        tw(pill,  {BackgroundColor3 = on and onColor or C.off}, 0.14)
        tw(knob,  {Position = on
            and UDim2.fromOffset(kOff, 4)
            or  UDim2.fromOffset(4, 4)}, 0.14)
        tw(cs,    {Color = on and onColor or C.off}, 0.14)
        pillTxt.Text = on and "ON" or "OFF"
    end

    hit.MouseButton1Click:Connect(function()
        Config[cfgKey] = not Config[cfgKey]
        refresh()
        -- side effect handlers
        if cfgKey == "ProjVoidEnabled" then
            if Config[cfgKey] and Config.Enabled then
                startProjVoid()
            elseif not Config[cfgKey] then
                stopProjVoid()
            end
        end
        if cfgKey == "JitterEnabled" or cfgKey == "SlingEnabled"
           or cfgKey == "SlingPingScale" then
            -- no extra action needed, value is read each cycle
        end
        -- icon bounce
        tw(card, {BackgroundColor3 = Color3.fromRGB(30,34,58)}, 0.07)
        task.delay(0.1, function()
            tw(card, {BackgroundColor3 = C.card}, 0.12)
        end)
    end)

    hit.MouseEnter:Connect(function()
        tw(card, {BackgroundColor3 = Color3.fromRGB(28,32,56)}, 0.1)
    end)
    hit.MouseLeave:Connect(function()
        tw(card, {BackgroundColor3 = C.card}, 0.1)
    end)
end

-- ── slider row ───────────────────────────────────────────────
local function mkSlider(title, cfgKey, min, max, decimals, suffix, fillColor)
    local h = isMobile and 70 or 62
    fillColor = fillColor or C.accent

    local card = Instance.new("Frame")
    card.LayoutOrder      = nextOrder()
    card.Size             = UDim2.new(1, 0, 0, h)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    mkCorner(card, 12)
    mkStroke(card, C.off, 1.5)

    local fmt = decimals > 0
        and ("%." .. decimals .. "f")
        or  "%d"

    local valLbl = mkLabel(card,
        title .. "  " .. string.format(fmt, Config[cfgKey]) .. (suffix or ""),
        isMobile and 13 or 12, C.text, Enum.Font.GothamBold)
    valLbl.Size     = UDim2.new(1, -16, 0, 20)
    valLbl.Position = UDim2.fromOffset(12, 10)

    local trackBg = Instance.new("Frame")
    trackBg.Size             = UDim2.new(1, -24, 0, isMobile and 12 or 10)
    trackBg.Position         = UDim2.fromOffset(12, h - (isMobile and 24 or 22))
    trackBg.BackgroundColor3 = C.off
    trackBg.BorderSizePixel  = 0
    trackBg.Parent           = card
    mkCorner(trackBg, 5)

    local pct  = (Config[cfgKey] - min) / (max - min)
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.fromScale(math.clamp(pct, 0, 1), 1)
    fill.BackgroundColor3 = fillColor
    fill.BorderSizePixel  = 0
    fill.Parent           = trackBg
    mkCorner(fill, 5)

    local dragging = false
    local function updateVal(x)
        local rel = math.clamp(
            (x - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X,
            0, 1
        )
        local raw = min + rel * (max - min)
        local val = decimals > 0
            and math.floor(raw * 10^decimals + 0.5) / 10^decimals
            or  math.floor(raw + 0.5)
        Config[cfgKey] = val
        fill.Size      = UDim2.fromScale(rel, 1)
        valLbl.Text    = title .. "  " .. string.format(fmt, val) .. (suffix or "")
    end

    local hitArea = Instance.new("TextButton")
    hitArea.Size               = UDim2.new(1, 0, 1, isMobile and 20 or 14)
    hitArea.Position           = UDim2.fromOffset(0, -(isMobile and 10 or 7))
    hitArea.BackgroundTransparency = 1
    hitArea.Text               = ""
    hitArea.ZIndex             = 5
    hitArea.Parent             = trackBg

    -- PC mouse
    hitArea.MouseButton1Down:Connect(function(x) dragging=true updateVal(x) end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateVal(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Mobile touch
    hitArea.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateVal(inp.Position.X)
        end
    end)
    hitArea.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.Touch then
            updateVal(inp.Position.X)
        end
    end)
    hitArea.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- ── dropdown row ─────────────────────────────────────────────
local function mkDropdown(title, cfgKey, options, fillColor)
    fillColor = fillColor or C.accent
    local h   = isMobile and 58 or 50

    local card = Instance.new("Frame")
    card.LayoutOrder      = nextOrder()
    card.Size             = UDim2.new(1, 0, 0, h)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    card.ClipsDescendants = false
    card.Parent           = Scroll
    mkCorner(card, 12)
    mkStroke(card, C.off, 1.5)

    local tLbl = mkLabel(card, title, isMobile and 13 or 12, C.sub, Enum.Font.GothamSemibold)
    tLbl.Size     = UDim2.new(0.45, 0, 1, 0)
    tLbl.Position = UDim2.fromOffset(12, 0)

    local valBtn = Instance.new("TextButton")
    valBtn.Size             = UDim2.new(0.5, 0, 0, h - 16)
    valBtn.Position         = UDim2.new(0.48, 0, 0.5, -(h-16)/2)
    valBtn.BackgroundColor3 = C.surface
    valBtn.TextColor3       = C.white
    valBtn.Font             = Enum.Font.GothamBold
    valBtn.TextSize         = isMobile and 13 or 12
    valBtn.Text             = Config[cfgKey] .. " ▾"
    valBtn.BorderSizePixel  = 0
    valBtn.ZIndex           = 2
    valBtn.Parent           = card
    mkCorner(valBtn, 8)

    local dropFrame = Instance.new("Frame")
    dropFrame.Size             = UDim2.new(0.5, 0, 0, #options * (isMobile and 40 or 34))
    dropFrame.Position         = UDim2.new(0.48, 0, 1, 4)
    dropFrame.BackgroundColor3 = C.surface
    dropFrame.BorderSizePixel  = 0
    dropFrame.Visible          = false
    dropFrame.ZIndex           = 20
    dropFrame.Parent           = card
    mkCorner(dropFrame, 8)
    mkStroke(dropFrame, fillColor, 1.5)

    local dList = Instance.new("UIListLayout")
    dList.SortOrder = Enum.SortOrder.LayoutOrder
    dList.Parent    = dropFrame

    for i, opt in ipairs(options) do
        local ob = Instance.new("TextButton")
        ob.LayoutOrder      = i
        ob.Size             = UDim2.new(1, 0, 0, isMobile and 40 or 34)
        ob.BackgroundColor3 = Config[cfgKey] == opt and fillColor or C.surface
        ob.TextColor3       = C.white
        ob.Font             = Enum.Font.GothamSemibold
        ob.TextSize         = isMobile and 13 or 12
        ob.Text             = opt
        ob.BorderSizePixel  = 0
        ob.ZIndex           = 21
        ob.Parent           = dropFrame
        if i == 1 then mkCorner(ob, 8) end

        ob.MouseButton1Click:Connect(function()
            Config[cfgKey] = opt
            valBtn.Text    = opt .. " ▾"
            dropFrame.Visible = false
            -- colour all options
            for _, c in ipairs(dropFrame:GetChildren()) do
                if c:IsA("TextButton") then
                    c.BackgroundColor3 = c.Text == opt and fillColor or C.surface
                end
            end
            nearestCache = nil  -- reset nearest cache on target change
        end)
    end

    local open = false
    valBtn.MouseButton1Click:Connect(function()
        open = not open
        dropFrame.Visible = open
    end)

    -- close when clicking elsewhere
    UserInputService.InputBegan:Connect(function(inp)
        if open and (inp.UserInputType == Enum.UserInputType.MouseButton1
                  or inp.UserInputType == Enum.UserInputType.Touch) then
            task.defer(function()
                if dropFrame.Visible then
                    dropFrame.Visible = false
                    open = false
                end
            end)
        end
    end)
end

