-- generic toggle card
local function mkToggle(title, sub, cfgKey, onColor, onChangeCb)
    local h   = isMobile and 62 or 54
    onColor   = onColor or C.accent

    local card = Instance.new("Frame")
    card.LayoutOrder      = nO()
    card.Size             = UDim2.new(1,0,0,h)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    mkCorner(card,12)
    local cs = mkStroke(card,C.off,1.5)

    local tLbl = mkLabel(card,title,isMobile and 14 or 13,C.text,Enum.Font.GothamBold)
    tLbl.Size     = UDim2.new(1,-90,0,20)
    tLbl.Position = UDim2.fromOffset(12, sub~="" and h/2-14 or h/2-10)

    if sub ~= "" then
        local sLbl = mkLabel(card,sub,isMobile and 11 or 10,C.sub,Enum.Font.Gotham)
        sLbl.Size     = UDim2.new(1,-90,0,14)
        sLbl.Position = UDim2.fromOffset(12,h/2+2)
    end

    local pw  = isMobile and 58 or 52
    local ph  = isMobile and 28 or 24
    local kSz = isMobile and 20 or 18

    local pill = Instance.new("Frame")
    pill.Size             = UDim2.fromOffset(pw,ph)
    pill.Position         = UDim2.new(1,-(pw+10),0.5,-ph/2)
    pill.BackgroundColor3 = Config[cfgKey] and onColor or C.off
    pill.BorderSizePixel  = 0
    pill.Parent           = card
    mkCorner(pill,ph/2)

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.fromOffset(kSz,kSz)
    knob.Position         = Config[cfgKey]
        and UDim2.fromOffset(pw-kSz-4,4) or UDim2.fromOffset(4,4)
    knob.BackgroundColor3 = C.white
    knob.BorderSizePixel  = 0
    knob.Parent           = pill
    mkCorner(knob,kSz/2)

    local pillTxt = mkLabel(pill,Config[cfgKey] and "ON" or "OFF",
        9,C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
    pillTxt.Size = UDim2.fromScale(1,1)

    local hit = Instance.new("TextButton")
    hit.Size               = UDim2.fromScale(1,1)
    hit.BackgroundTransparency=1
    hit.Text               = ""
    hit.ZIndex             = 5
    hit.Parent             = card

    local function refresh()
        local on = Config[cfgKey]
        tw(pill,{BackgroundColor3=on and onColor or C.off},0.14)
        tw(knob,{Position=on
            and UDim2.fromOffset(pw-kSz-4,4)
            or  UDim2.fromOffset(4,4)},0.14)
        tw(cs,{Color=on and onColor or C.off},0.14)
        pillTxt.Text = on and "ON" or "OFF"
    end

    hit.MouseButton1Click:Connect(function()
        Config[cfgKey] = not Config[cfgKey]
        refresh()
        if onChangeCb then onChangeCb(Config[cfgKey]) end
        tw(card,{BackgroundColor3=Color3.fromRGB(30,34,58)},0.07)
        task.delay(0.1,function() tw(card,{BackgroundColor3=C.card},0.12) end)
    end)
    hit.MouseEnter:Connect(function() tw(card,{BackgroundColor3=Color3.fromRGB(28,32,56)},0.1) end)
    hit.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.card},0.1) end)
end

-- generic slider card
local function mkSlider(title, cfgKey, mn, mx, decimals, suffix, fillColor, onChangeCb)
    local h = isMobile and 70 or 62
    fillColor = fillColor or C.accent

    local card = Instance.new("Frame")
    card.LayoutOrder      = nO()
    card.Size             = UDim2.new(1,0,0,h)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    mkCorner(card,12)
    mkStroke(card,C.off,1.5)

    local fmt = decimals>0 and ("%."..decimals.."f") or "%d"

    local valLbl = mkLabel(card,
        title.."  "..string.format(fmt,Config[cfgKey])..(suffix or ""),
        isMobile and 13 or 12,C.text,Enum.Font.GothamBold)
    valLbl.Size     = UDim2.new(1,-16,0,20)
    valLbl.Position = UDim2.fromOffset(12,10)

    local trackBg = Instance.new("Frame")
    trackBg.Size             = UDim2.new(1,-24,0,isMobile and 12 or 10)
    trackBg.Position         = UDim2.fromOffset(12,h-(isMobile and 24 or 22))
    trackBg.BackgroundColor3 = C.off
    trackBg.BorderSizePixel  = 0
    trackBg.Parent           = card
    mkCorner(trackBg,5)

    local pct  = (Config[cfgKey]-mn)/(mx-mn)
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.fromScale(math.clamp(pct,0,1),1)
    fill.BackgroundColor3 = fillColor
    fill.BorderSizePixel  = 0
    fill.Parent           = trackBg
    mkCorner(fill,5)

    local dragging = false
    local function updateVal(x)
        local rel = math.clamp((x-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
        local raw = mn + rel*(mx-mn)
        local val = decimals>0
            and math.floor(raw*10^decimals+0.5)/10^decimals
            or  math.floor(raw+0.5)
        Config[cfgKey] = val
        fill.Size      = UDim2.fromScale(rel,1)
        valLbl.Text    = title.."  "..string.format(fmt,val)..(suffix or "")
        if onChangeCb then onChangeCb(val) end
    end

    local hitArea = Instance.new("TextButton")
    hitArea.Size               = UDim2.new(1,0,1,isMobile and 20 or 14)
    hitArea.Position           = UDim2.fromOffset(0,-(isMobile and 10 or 7))
    hitArea.BackgroundTransparency=1
    hitArea.Text               = ""
    hitArea.ZIndex             = 5
    hitArea.Parent             = trackBg

    hitArea.MouseButton1Down:Connect(function(x) dragging=true updateVal(x) end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType==Enum.UserInputType.MouseMovement then
            updateVal(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    hitArea.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch then dragging=true updateVal(inp.Position.X) end
    end)
    hitArea.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType==Enum.UserInputType.Touch then updateVal(inp.Position.X) end
    end)
    hitArea.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch then dragging=false end
    end)
end

