local function loadHandicapController()
    if Config.HandicapLoaded then return true end
    local ok, dc = pcall(function()
        return require(
            LP.PlayerScripts
              :WaitForChild("Controllers", 5)
              :WaitForChild("DebugController", 5)
        )
    end)
    if ok and dc then
        Config.DebugController = dc
        Config.HandicapLoaded  = true
        print("[exploit] DebugController acquired")
        return true
    end
    warn("[exploit] DebugController not found — aim assist hardware path unavailable")
    return false
end

local function enableHandicap(state)
    if not Config.HandicapLoaded then
        if not loadHandicapController() then return end
    end
    pcall(function()
        Config.DebugController:SetHandicapsEnabled(state)
    end)
    print("[exploit] SetHandicapsEnabled(" .. tostring(state) .. ")")
end

-- ─────────────────────────────────────────────────────────────
--  AIM ASSIST  (smooth camera pull toward nearest enemy head)
--  Works on PC. On mobile the camera is already touch-driven
--  so we skip the CFrame manipulation and rely on the handicap.
-- ─────────────────────────────────────────────────────────────
local isMobile = UserInputService.TouchEnabled
                 and not UserInputService.KeyboardEnabled

local function getNearestInFOV(fov)
    local vp     = Cam.ViewportSize
    local center = Vector2.new(vp.X/2, vp.Y/2)
    local best, bestDist = nil, math.huge
    for _, p in ipairs(playerCache) do
        local chr  = p.Character
        local head = chr and chr:FindFirstChild("Head")
        local hum  = chr and chr:FindFirstChildOfClass("Humanoid")
        if head and hum and hum.Health > 0 then
            local sp, onScreen = Cam:WorldToScreenPoint(head.Position)
            if onScreen then
                local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if d < fov and d < bestDist then
                    bestDist = d best = p
                end
            end
        end
    end
    return best, bestDist
end

local SHOOT_KW = {
    "shoot","fire","attack","cast","launch",
    "throw","use","action","hit","trigger","release",
}

local function fireCurrentTool()
    local chr  = LP.Character
    if not chr then return end
    local tool = chr:FindFirstChildOfClass("Tool")
    if not tool then return end
    pcall(function() tool:Activate() end)
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local nl = v.Name:lower()
            for _, kw in ipairs(SHOOT_KW) do
                if nl:find(kw) then
                    pcall(function() v:FireServer() end)
                    break
                end
            end
        end
    end
end

local function startAim()
    if Config.AimConn then Config.AimConn:Disconnect() end

    -- enable the game's own handicap system
    enableHandicap(true)

    if isMobile then
        -- on mobile the handicap does the heavy lifting
        -- no CFrame manipulation needed
        print("[exploit] Aim assist: mobile mode (handicap only)")
        return
    end

    -- PC: smooth camera pull every RenderStepped
    Config.AimConn = RunService.RenderStepped:Connect(function()
        if not Config.AimEnabled then return end

        local target, dist = getNearestInFOV(Config.AimFOV)
        if not target then return end

        local head = target.Character and target.Character:FindFirstChild("Head")
        if not head then return end

        -- smooth interpolation toward head
        local smooth = math.clamp(Config.AimSmooth, 0, 0.99)
        local goalCF = CFrame.new(Cam.CFrame.Position, head.Position)
        Cam.CFrame   = Cam.CFrame:Lerp(goalCF, 1 - smooth)

        -- auto shoot if within tighter FOV
        if Config.AutoShoot and dist < Config.AutoShootFOV then
            fireCurrentTool()
        end
    end)
end

local function stopAim()
    if Config.AimConn then Config.AimConn:Disconnect() Config.AimConn=nil end
    enableHandicap(false)
end

-- ─────────────────────────────────────────────────────────────
--  DESYNC  (position spoofing — the two-script technique)
--
--  How it works:
--    Heartbeat  → teleport HRP to a random coordinate so the
--                 server sees a crazy position (anti-lag, resolver break)
--    RenderStep → immediately restore the real CFrame so locally
--                 you see yourself standing still
--
--  Intensity slider scales the random range:
--    0.0 = off
--    0.5 = ±500M studs
--    1.0 = ±2.1B studs (full original range)
-- ─────────────────────────────────────────────────────────────

-- same betterRandom as the original — avoids the "dead zone" near 0
local function betterRandom(mi, ma, dmi, dma)
    local val = math.random(mi, ma)
    local iter = 0
    repeat
        val  = math.random(mi, ma)
        iter = iter + 1
    until val < dmi or val > dma or iter > 20
    return val
end

local desyncHRP   = nil
local desyncCF    = nil
local desyncLV    = nil
local desyncAV    = nil

local function startDesync()
    if Config.DesyncHBConn then Config.DesyncHBConn:Disconnect() end
    if Config.DesyncRSConn then Config.DesyncRSConn:Disconnect() end

    Config.DesyncHBConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local chr = LP.Character
            desyncHRP = chr and chr:FindFirstChild("HumanoidRootPart")
            if not desyncHRP then return end

            -- save real state
            desyncCF = desyncHRP.CFrame
            desyncLV = desyncHRP.AssemblyLinearVelocity
            desyncAV = desyncHRP.AssemblyAngularVelocity

            -- scale range by intensity
            local intensity = Config.DesyncIntensity
            local R  = math.floor(2147483646 * intensity)
            local DR = math.floor(1147483646 * intensity)
            if R  < 2 then R  = 2  end
            if DR < 1 then DR = 1  end
            if DR >= R then DR = R - 1 end

            local rx = betterRandom(-R, R, -DR, DR)
            local ry = betterRandom(-R, R, -DR, DR)
            local rz = betterRandom(-R, R, -DR, DR)

            -- spoof to server
            desyncHRP.CFrame = CFrame.new(rx, ry, rz)
                * CFrame.Angles(math.rad(math.pi), math.rad(math.pi), math.rad(math.pi))
            desyncHRP.AssemblyLinearVelocity = Vector3.new(
                betterRandom(-R, R, -DR, DR),
                betterRandom(-R, R, -DR, DR),
                betterRandom(-R, R, -DR, DR)
            )
            desyncHRP.AssemblyAngularVelocity = Vector3.new(
                betterRandom(-R, R, -DR, DR),
                betterRandom(-R, R, -DR, DR),
                betterRandom(-R, R, -DR, DR)
            )
        end)
    end)

    -- restore before render — client sees real position
    RunService:BindToRenderStep("_desync_restore", Enum.RenderPriority.First.Value, function()
        if desyncHRP then
            pcall(function()
                desyncHRP.CFrame = desyncCF
                desyncHRP.AssemblyLinearVelocity  = desyncLV
                desyncHRP.AssemblyAngularVelocity = desyncAV
            end)
        end
    end)

    Config.DesyncRSConn = true  -- flag so we know to unbind
end

local function stopDesync()
    if Config.DesyncHBConn then
        Config.DesyncHBConn:Disconnect()
        Config.DesyncHBConn = nil
    end
    if Config.DesyncRSConn then
        pcall(function() RunService:UnbindFromRenderStep("_desync_restore") end)
        Config.DesyncRSConn = nil
    end
    desyncHRP = nil
end

-- ─────────────────────────────────────────────────────────────
--  PROJECTILE VOID
-- ─────────────────────────────────────────────────────────────
local projTracked = {}

local function startProjVoid()
    if Config.ProjChildAdd then Config.ProjChildAdd:Disconnect() end
    if Config.ProjConn     then Config.ProjConn:Disconnect()     end

    local VOID = CFrame.new(9e3, 9e3, 9e3)

    Config.ProjChildAdd = workspace.ChildAdded:Connect(function(o)
        if o.Name == "CoreProjectile" and o:IsA("BasePart") then
            projTracked[o] = true
        end
    end)
    workspace.DescendantAdded:Connect(function(o)
        if o.Name == "CoreProjectile" and o:IsA("BasePart") then
            projTracked[o] = true
        end
    end)
    Config.ProjChildRem = workspace.ChildRemoved:Connect(function(o)
        projTracked[o] = nil
    end)
    for _, d in ipairs(workspace:GetDescendants()) do
        if d.Name == "CoreProjectile" and d:IsA("BasePart") then
            projTracked[d] = true
        end
    end

    Config.ProjConn = RunService.Heartbeat:Connect(function()
        if not Config.ProjVoidEnabled then return end
        for part in pairs(projTracked) do
            if part and part.Parent then
                part.CFrame = VOID
                part.AssemblyLinearVelocity  = Vector3.zero
                part.AssemblyAngularVelocity = Vector3.zero
            else
                projTracked[part] = nil
            end
        end
    end)
end

local function stopProjVoid()
    if Config.ProjChildAdd then Config.ProjChildAdd:Disconnect() Config.ProjChildAdd=nil end
    if Config.ProjChildRem then Config.ProjChildRem:Disconnect() Config.ProjChildRem=nil end
    if Config.ProjConn     then Config.ProjConn:Disconnect()     Config.ProjConn=nil     end
    projTracked = {}
end

-- ─────────────────────────────────────────────────────────────
--  TARGET SELECTION
-- ─────────────────────────────────────────────────────────────
local function getTarget()
    if #playerCache == 0 then return nil end
    if Config.TargetMode == "Closest" then
        return getNearestEnemy()
    elseif Config.TargetMode == "LowestHP" then
        local best, bHP = nil, math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health < bHP then bHP=hum.Health best=p end
        end
        return best
    elseif Config.TargetMode == "HighestHP" then
        local best, bHP = nil, -math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health > bHP then bHP=hum.Health best=p end
        end
        return best
    end
    return getNearestEnemy()
end

-- ─────────────────────────────────────────────────────────────
--  PING-COMPENSATED TIMING
-- ─────────────────────────────────────────────────────────────
local function scaledHideTime()
    if not Config.SlingPingScale then return Config.HideTime end
    local scale = math.clamp(1 - (getPing() - 30) / 400, 0.55, 1.0)
    return Config.HideTime * scale
end

local function scaledAttackTime()
    if not Config.SlingPingScale then return Config.AttackTime end
    local scale = math.clamp(1 + (getPing() - 30) / 300, 1.0, 1.8)
    return Config.AttackTime * scale
end

-- ─────────────────────────────────────────────────────────────
--  VOID SPAM CYCLE
-- ─────────────────────────────────────────────────────────────
local function runCycle()
    if Config.VoidRunning then return end
    Config.VoidRunning = true

    local target = getTarget()
    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then Config.VoidRunning=false return end

    local origCF = myHRP.CFrame
    local jx = Config.JitterEnabled and (math.random()-0.5)*2*Config.JitterRange or 0
    local jz = Config.JitterEnabled and (math.random()-0.5)*2*Config.JitterRange or 0

    local hideCF = CFrame.new(origCF.Position.X+jx, Config.HideY, origCF.Position.Z+jz)

    -- PHASE 1: sink
    myHRP.CFrame = hideCF
    myHRP.AssemblyLinearVelocity  = Vector3.zero
    myHRP.AssemblyAngularVelocity = Vector3.zero

    task.wait(scaledHideTime())

    -- PHASE 2: snap + fire
    local tChr = target and target.Character
    local tHRP = tChr  and tChr:FindFirstChild("HumanoidRootPart")

    if tHRP then
        local snapCF = CFrame.new(
            tHRP.Position.X,
            tHRP.Position.Y + 2.5,
            tHRP.Position.Z
        ) * CFrame.Angles(0, math.random(0,628)/100, 0)

        myHRP.CFrame = snapCF
        myHRP.AssemblyLinearVelocity  = Vector3.zero
        myHRP.AssemblyAngularVelocity = Vector3.zero

        if Config.SlingEnabled then
            for i = 1, Config.SlingShots do
                fireCurrentTool()
                if i < Config.SlingShots then task.wait(Config.SlingDelay) end
            end
        end

        task.wait(scaledAttackTime())
    end

    -- PHASE 3: return
    myHRP.CFrame = hideCF
    myHRP.AssemblyLinearVelocity = Vector3.zero
    task.wait(Config.ReturnDelay)
    myHRP.CFrame = origCF
    myHRP.AssemblyLinearVelocity = Vector3.zero

    Config.VoidRunning = false
end

-- ─────────────────────────────────────────────────────────────
--  START / STOP VOID SPAM
-- ─────────────────────────────────────────────────────────────
local function startVoidSpam()
    Config.VoidEnabled  = true
    Config.VoidRunning  = false
    if Config.ProjVoidEnabled then startProjVoid() end
    Config.VoidCycleConn = RunService.Heartbeat:Connect(function()
        if Config.VoidEnabled and not Config.VoidRunning then
            task.spawn(runCycle)
        end
    end)
end

local function stopVoidSpam()
    Config.VoidEnabled  = false
    Config.VoidRunning  = false
    if Config.VoidCycleConn then
        Config.VoidCycleConn:Disconnect()
        Config.VoidCycleConn = nil
    end
    stopProjVoid()
    pcall(function()
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Position.Y < -50 then
            local sp = workspace:FindFirstChild("SpawnLocation")
            hrp.CFrame = sp and sp.CFrame + Vector3.new(0,5,0) or CFrame.new(0,10,0)
        end
    end)
end

