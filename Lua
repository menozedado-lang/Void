-- ─────────────────────────────────────────────────────────────
--  PING UTILITY
--  Rivals is ping-based for slingshot hit reg.
--  We read real network ping and scale our bypass timings.
-- ─────────────────────────────────────────────────────────────
local function getPing()
    -- Stats.Network is the most accurate client-side ping source
    local ok, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    return ok and ping or 80  -- fallback 80ms if unavailable
end

