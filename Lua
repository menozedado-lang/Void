--  RESPAWN HANDLER
-- ─────────────────────────────────────────────────────────────
LP.CharacterAdded:Connect(function()
    Config.Running = false
    projTracked    = {}
    nearestCache   = nil

    task.wait(0.5)
    rebuildCache()

    if Config.Enabled then
        stopVoidSpam()
        task.wait(0.3)
        startVoidSpam()
    end
end)

