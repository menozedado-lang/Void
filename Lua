    card.Parent           = Scroll
    mkCorner(card,12)
    mkStroke(card,C.off,1.5)

    local tLbl = mkLabel(card,title,isMobile and 13 or 12,C.sub,Enum.Font.GothamSemibold)
    tLbl.Size     = UDim2.new(0.45,0,1,0)
    tLbl.Position = UDim2.fromOffset(12,0)

    local valBtn = Instance.new("TextButton")
    valBtn.Size             = UDim2.new(0.5,0,0,h-16)
    valBtn.Position         = UDim2.new(0.48,0,0.5,-(h-16)/2)
    valBtn.BackgroundColor3 = C.surface
    valBtn.TextColor3       = C.white
    valBtn.Font             = Enum.Font.GothamBold
    valBtn.TextSize         = isMobile and 13 or 12
    valBtn.Text             = Config[cfgKey].." ▾"
    valBtn.BorderSizePixel  = 0
    valBtn.ZIndex           = 2
    valBtn.Parent           = card
    mkCorner(valBtn,8)

    local dropFrame = Instance.new("Frame")
    dropFrame.Size             = UDim2.new(0.5,0,0,#options*(isMobile and 40 or 34))
    dropFrame.Position         = UDim2.new(0.48,0,1,4)
    dropFrame.BackgroundColor3 = C.surface
    dropFrame.BorderSizePixel  = 0
    dropFrame.Visible          = false
    dropFrame.ZIndex           = 20
    dropFrame.Parent           = card
    mkCorner(dropFrame,8)
    mkStroke(dropFrame,fillColor,1.5)

    local dList = Instance.new("UIListLayout")
    dList.SortOrder = Enum.SortOrder.LayoutOrder
    dList.Parent    = dropFrame

    for i, opt in ipairs(options) do
        local ob = Instance.new("TextButton")
        ob.LayoutOrder      = i
        ob.Size             = UDim2.new(1,0,0,isMobile and 40 or 34)
        ob.BackgroundColor3 = Config[cfgKey]==opt and fillColor or C.surface
        ob.TextColor3       = C.white
        ob.Font             = Enum.Font.GothamSemibold
        ob.TextSize         = isMobile and 13 or 12
        ob.Text             = opt
        ob.BorderSizePixel  = 0
        ob.ZIndex           = 21
        ob.Parent           = dropFrame

        ob.MouseButton1Click:Connect(function()
            Config[cfgKey] = opt
            valBtn.Text    = opt.." ▾"
            dropFrame.Visible = false
            nearestCache   = nil
            for _, ch in ipairs(dropFrame:GetChildren()) do
                if ch:IsA("TextButton") then
                    ch.BackgroundColor3 = ch.Text==opt and fillColor or C.surface
                end
            end
        end)
    end

    local open = false
    valBtn.MouseButton1Click:Connect(function() open=not open dropFrame.Visible=open end)
    UserInputService.InputBegan:Connect(function(inp)
        if open and (inp.UserInputType==Enum.UserInputType.MouseButton1
                  or inp.UserInputType==Enum.UserInputType.Touch) then
            task.defer(function()
                if dropFrame.Visible then dropFrame.Visible=false open=false end
            end)
        end
    end)
end

