local playerCache = {}
local function rebuildCache()
    playerCache = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(playerCache, p) end
    end
end
rebuildCache()
Players.PlayerAdded:Connect(rebuildCache)
Players.PlayerRemoving:Connect(function() task.defer(rebuildCache) end)

-- ─────────────────────────────────────────────────────────────
--  NEAREST ENEMY  (cached per frame to avoid repeated loops)
-- ─────────────────────────────────────────────────────────────
local nearestCache     = nil
local nearestCacheTime = 0
local NEAREST_TTL      = 0.08  -- seconds

local function getNearestEnemy()
    local now = tick()
    if now - nearestCacheTime < NEAREST_TTL then return nearestCache end
    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then nearestCache=nil nearestCacheTime=now return nil end
    local best, bestDSq = nil, math.huge
    for _, p in ipairs(playerCache) do
        local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - myHRP.Position).Magnitude
            if d * d < bestDSq then bestDSq = d*d best = p end
        end
    end
    nearestCache     = best
    nearestCacheTime = now
    return best
end

